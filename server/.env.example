# MongoDB
MONGODB_URI=your-mongodb-uri-here

# JWT (change this to a long random string in production)
JWT_SECRET=your-long-random-jwt-secret-here

# Session (change this to a long random string in production)
SESSION_SECRET=your-long-random-session-secret-here

# Brevo Email API (https://app.brevo.com → API Keys)
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SENDER_EMAIL=your-verified-sender@yourdomain.com

# AWS S3 (used for all resume uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET_NAME=your-s3-bucket-name

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# AI Service URL (local dev default: http://127.0.0.1:5001)
AI_SERVICE_URL=http://127.0.0.1:5001

# URLs
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# Environment
NODE_ENV=development
